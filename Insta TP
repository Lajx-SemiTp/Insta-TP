spawn(function()
    while MainFrame.Parent do
        local dt = task.wait(0.04)
        for i = #snowflakes, 1, -1 do
            local s = snowflakes[i]
            if not s.label.Parent then
                table.remove(snowflakes, i)
                continue
            end
            s.y = s.y + s.speed * dt
            s.driftTimer = s.driftTimer + dt
            if s.driftTimer > math.random(10, 25) / 10 then
                s.driftDir = -s.driftDir
                s.driftTimer = 0
            end
            s.x = s.x + s.drift * s.driftDir * dt
            if s.x < 0 then s.x = 0 s.driftDir = 1 end
            if s.x > 0.95 then s.x = 0.95 s.driftDir = -1 end
            s.label.Position = UDim2.new(s.x, 0, s.y, 0)
            if s.y > 1.05 then
                s.y = -0.05
                s.x = math.random(0, 100) / 100
                local symbols = {"•", "·", "*", "❄", "✦", "◦"}
