            local runAnim = runFolder:FindFirstChild("RunAnim")
            if runAnim and runAnim:IsA("Animation") then
                UnwalkConfig.OriginalRunAnimId = runAnim.AnimationId
            end
        end
    end
    local walkFolder = animate:FindFirstChild("walk")
