local function executeTPWithAutoGrab()
    local root = getRoot()
    if not root then return end
    local carpet = getFlyingCarpet()
    if not carpet then return end
    if carpet.Parent == LocalPlayer.Backpack and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character.Humanoid:EquipTool(carpet)
        task.wait(0.1)
    end
    local targetAnimal = getNearestAnimal()
    local prompt = nil
    if targetAnimal and shouldSteal(targetAnimal) then
        prompt = findProximityPromptForAnimal(targetAnimal)
    end
    if prompt then
        buildStealCallbacks(prompt)
        if not InternalStealCache[prompt] then prompt = nil end
    end
    local targetBase = getTargetBase()
    if prompt then
        local data = InternalStealCache[prompt]
        if data and data.ready then
            data.ready = false
            IsStealing = true
            StealProgress = 0
            CurrentStealTarget = targetAnimal
            StealStartTime = tick()
            if #data.holdCallbacks > 0 then
                for _, fn in ipairs(data.holdCallbacks) do task.spawn(fn) end
            end
            task.spawn(function()
                task.wait(0.85)
                if targetBase == 1 then root.CFrame = CFrame.new(-349.402, -7.471, 111.663)
                else root.CFrame = CFrame.new(-352.274, -7.721, 9.795) end
                task.wait(0.15)
                if targetBase == 1 then root.CFrame = CFrame.new(-334.661, -6.799, 102.386)
                else root.CFrame = CFrame.new(-336.610, -5.971, 18.290) end
                task.wait(0.28)
                if targetBase == 1 then root.CFrame = CFrame.new(-351.202, -6.763, 74.376)
                else root.CFrame = CFrame.new(-351.202, -6.763, 46.001) * CFrame.Angles(0, math.rad(183.5), 0) end
            end)
            task.spawn(function()
                local startTime = tick()
                while tick() - startTime < 1.3 do
                    StealProgress = (tick() - startTime) / 1.3
                    task.wait(0.05)
                end
                StealProgress = 1
                if #data.triggerCallbacks > 0 then
                    for _, fn in ipairs(data.triggerCallbacks) do task.spawn(fn) end
                end
                task.wait(0.1)
                data.ready = true
                task.wait(0.2)
                IsStealing = false
                StealProgress = 0
                CurrentStealTarget = nil
                InternalStealCache[prompt] = nil
                triggerAdminSpam()
            end)
        end
    else
        if targetBase == 1 then executeBase1Sequence()
        else executeBase2Sequence() end
        triggerAdminSpam()
    end
    activateStealBoost(5)
    findAndActivateProximityPrompt()
end

