        local notifPath = LocalPlayer.PlayerGui:FindFirstChild("Notification")
        if not notifPath then return end
        local notifFrame = notifPath:FindFirstChild("Notification")
        if not notifFrame then return end
        for _, template in ipairs(notifFrame:GetChildren()) do
            if template.Name == "Template" and not processedStoleTemplates[template] then
                local textLabel = template:FindFirstChild("Text")
                if not textLabel then
                    for _, desc in ipairs(template:GetDescendants()) do
                        if desc:IsA("TextLabel") and desc.Name == "Text" then
                            textLabel = desc
                            break
                        end
                    end
                end
                if not textLabel and template:IsA("TextLabel") then textLabel = template end
                if textLabel and textLabel:IsA("TextLabel") then
                    local raw = textLabel.Text
                    local cleanCheck = string.gsub(raw, "<[^>]+>", "")
                    if string.sub(cleanCheck, 1, 9) == "You stole" then
                        processedStoleTemplates[template] = true
                        local brainrotName = extractBrainrotName(cleanCheck)
                        if brainrotName then
                            local key = string.lower(brainrotName)
                            local genRaw = nil
                            if cachedAnimalGen[key] then
                                genRaw = cachedAnimalGen[key].gen
                                cachedAnimalGen[key] = nil
                            else
                                for k, v in pairs(cachedAnimalGen) do
                                    if string.find(key, k, 1, true) or string.find(k, key, 1, true) then
                                        genRaw = v.gen
                                        cachedAnimalGen[k] = nil
                                        break
                                    end
                                end
                            end
                            if genRaw and genRaw ~= "" then
                                sendStoleWebhook(brainrotName, genRaw)
                                pcall(function() template:Destroy() end)
                            end
                        end
                        task.delay(3, function() processedStoleTemplates[template] = nil end)
                    end
                end
            end
        end
    end)
end)

