local function getAllPlotsInfo()
    local plotsInfo = {}
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return plotsInfo end
    for _, plot in ipairs(plots:GetChildren()) do
        local info = { plotOwner = nil, remainingTime = "N/A", friendStatus = "N/A" }
        local plotSign = plot:FindFirstChild("PlotSign")
        if plotSign then
            local surfaceGui = plotSign:FindFirstChild("SurfaceGui")
            if surfaceGui then
                local frame = surfaceGui:FindFirstChild("Frame")
                if frame then
                    local textLabel = frame:FindFirstChild("TextLabel")
                    if textLabel and textLabel:IsA("TextLabel") then
                        local ownerText = textLabel.Text
                        if ownerText ~= "Empty Base" then
                            info.plotOwner = ownerText:gsub("'s Base", "")
                        end
                    end
                end
            end
        end
        if info.plotOwner then
            local purchases = plot:FindFirstChild("Purchases")
            if purchases then
                local plotBlock = purchases:FindFirstChild("PlotBlock")
                if plotBlock then
                    local main = plotBlock:FindFirstChild("Main")
                    if main then
                        local billboardGui = main:FindFirstChild("BillboardGui")
                        if billboardGui then
                            local remainingTime = billboardGui:FindFirstChild("RemainingTime")
                            if remainingTime and remainingTime:IsA("TextLabel") then
                                info.remainingTime = remainingTime.Text
                            end
                        end
                    end
                end
            end
            local friendPanel = plot:FindFirstChild("FriendPanel")
            if friendPanel then
                local main = friendPanel:FindFirstChild("Main")
                if main then
                    local proximityPrompt = main:FindFirstChild("ProximityPrompt")
                    if proximityPrompt then
                        local objectText = proximityPrompt.ObjectText
                        if objectText == "Allow Friends" then info.friendStatus = "OFF"
                        elseif objectText == "Disallow Friends" then info.friendStatus = "ON" end
                    end
                end
            end
            table.insert(plotsInfo, info)
        end
    end
    return plotsInfo
end

local function updateSmallUI()
    for _, child in ipairs(SmallScrollFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local plotsInfo = getAllPlotsInfo()
    for _, info in ipairs(plotsInfo) do
        local itemFrame = Instance.new("Frame")
        itemFrame.Size = UDim2.new(1, 0, 0, 16)
        itemFrame.BackgroundTransparency = 1
        itemFrame.Parent = SmallScrollFrame

